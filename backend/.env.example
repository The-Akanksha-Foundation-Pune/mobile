DATABASE_URL="mysql://root:your_password@localhost:3306/LocalDB"
# Finance ERP cost centers (same MySQL server; user needs SELECT on Finance.costcenter)
FINANCE_COSTCENTER_TABLE=Finance.costcenter
# FINANCE_COSTCENTER_SYNC=false
# FINANCE_COSTCENTER_REQUIRED=true
# Override column names if auto-detect fails:
# Finance.costcenter columns (Akanksha ERP):
FINANCE_CC_COL_ID=id
FINANCE_CC_COL_NAME=costcenter
FINANCE_CC_COL_CITY=city
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=LocalDB
PORT=4000
# Optional — remote testing via ngrok (npm run tunnel:start); never commit a real token
# NGROK_AUTHTOKEN=your_ngrok_authtoken
JWT_SECRET=replace_with_long_random_secret
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com
GOOGLE_ANDROID_CLIENT_ID=your_google_oauth_android_client_id.apps.googleusercontent.com
GOOGLE_IOS_CLIENT_ID=your_google_oauth_ios_client_id.apps.googleusercontent.com
# Optional comma-separated fallback list, if you want one setting for all:
# GOOGLE_CLIENT_IDS=web.apps.googleusercontent.com,android.apps.googleusercontent.com,ios.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAIN=akanksha.org
GOOGLE_AI_API_KEY=your_google_ai_api_key
# Optional model override if default is unavailable for your project/key
# GOOGLE_AI_MODEL=gemini-2.0-flash
# Same key as Cursor Settings → Models → Google API Key (Google AI Studio)
GOOGLE_DRIVE_FOLDER_ID=your_google_drive_folder_id
GOOGLE_SERVICE_ACCOUNT_EMAIL=service-account@project-id.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Media: auto = Drive when fully configured, else local disk under backend/uploads + /media URLs
# MEDIA_STORAGE=auto
# Force disk-only (no Drive): MEDIA_STORAGE=local
# Force Drive only (503 if misconfigured): MEDIA_STORAGE=google
# Optional base URL for /media links when behind a proxy or ngrok:
# PUBLIC_API_BASE_URL=http://127.0.0.1:4000
# PUBLIC_API_BASE_URL=https://YOUR-SUBDOMAIN.ngrok-free.app
