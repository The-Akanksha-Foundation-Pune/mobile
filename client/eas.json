{
  "cli": {
    "version": ">= 15.0.0"
  },
  "build": {
    "preview": {
      "developmentClient": false,
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://mobile-sand-chi.vercel.app",
        "EXPO_PUBLIC_WEB_REDIRECT_URI": "https://mobile-sand-chi.vercel.app"
      },
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_API_BASE_URL": "https://mobile-sand-chi.vercel.app",
        "EXPO_PUBLIC_WEB_REDIRECT_URI": "https://mobile-sand-chi.vercel.app"
      },
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
