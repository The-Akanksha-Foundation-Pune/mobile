{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "start:lan": "expo start --host lan",
    "android": "expo run:android",
    "android:lan": "expo start --host lan",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:web": "expo export --platform web",
    "doctor": "npx expo-doctor",
    "android:fingerprints": "keytool -list -v -keystore \"$HOME/.android/debug.keystore\" -alias androiddebugkey -storepass android -keypass android 2>/dev/null | grep -E 'SHA1|SHA256' || (echo 'No debug keystore yet. Run: npx expo run:android' && exit 1)",
    "google:setup": "node scripts/print-google-oauth-setup.mjs",
    "google:setup:web": "node scripts/print-web-oauth-setup.mjs",
    "api:setup": "node scripts/print-api-setup.mjs",
    "api:ngrok": "node scripts/print-ngrok-setup.mjs",
    "api:sync-ngrok": "node scripts/sync-ngrok-api-url.mjs",
    "ngrok:auth": "node scripts/ensure-ngrok-auth.mjs",
    "build:android": "npx --yes eas-cli build --platform android --profile preview",
    "build:ios": "npx --yes eas-cli build --platform ios --profile preview"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "expo": "~54.0.35",
    "expo-auth-session": "~7.0.11",
    "expo-build-properties": "~1.0.10",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.12",
    "expo-image-picker": "~17.0.11",
    "expo-location": "~19.0.8",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.11",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
