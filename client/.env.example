# Physical Android/iOS devices cannot use 127.0.0.1 — use your computer's LAN IP.
# Find it: System Settings → Network, or run: ipconfig getifaddr en0
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.5:4000

# Remote testers (other city / mobile data): ngrok HTTPS URL after npm run api:sync-ngrok
# EXPO_PUBLIC_API_BASE_URL=https://YOUR-SUBDOMAIN.ngrok-free.app

# Vercel (set in Vercel → Project → Environment Variables; baked in at build time):
# Production: EXPO_PUBLIC_API_BASE_URL=https://mobile-sand-chi.vercel.app
# Preview (main branch): EXPO_PUBLIC_API_BASE_URL=https://mobile-git-main-akanksha-dev-teams-projects.vercel.app
EXPO_PUBLIC_API_BASE_URL=https://mobile-sand-chi.vercel.app
# Web Google OAuth redirect (add same URL in Google Console → Web client → Authorized redirect URIs)
EXPO_PUBLIC_WEB_REDIRECT_URI=https://mobile-sand-chi.vercel.app
